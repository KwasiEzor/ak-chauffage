# ==================================
# AK CHAUFFAGE - Production Environment Variables
# Copy this to Railway project settings
# ==================================

# ==================================
# NODE ENVIRONMENT
# ==================================
NODE_ENV=production
PORT=3001

# ==================================
# DATABASE (Railway PostgreSQL)
# ==================================
# This is automatically set by Railway when you add PostgreSQL
# DATABASE_URL=postgresql://user:password@host:port/database

# ==================================
# AUTHENTICATION
# ==================================
# Generate strong JWT secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-at-least-32-characters-long

# Admin credentials (create hash with: node -e "require('bcrypt').hash('YourPassword', 10, (e,h) => console.log(h))")
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$...your-bcrypt-hash-here...

# ==================================
# EMAIL SERVICE - RESEND (Primary)
# ==================================
RESEND_API_KEY=re_EFYzQgEe_F9xeTZpk9HibmzRXobHbkVCG
SMTP_FROM=AK CHAUFFAGE <noreply@ak-chauffage.be>
ADMIN_EMAIL=contact@ak-chauffage.be
CONTACT_EMAIL=contact@ak-chauffage.be

# ==================================
# EMAIL SERVICE - SMTP (Fallback)
# ==================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_EFYzQgEe_F9xeTZpk9HibmzRXobHbkVCG

# ==================================
# CLOUDINARY (Image Storage)
# ==================================
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret-key

# ==================================
# OPTIONAL: Analytics & Monitoring
# ==================================
# Add if you want to track errors
# SENTRY_DSN=https://...

# ==================================
# NOTES
# ==================================
# 1. Never commit .env files to git
# 2. Keep JWT_SECRET and passwords secure
# 3. Rotate API keys regularly
# 4. Use strong passwords for admin accounts
# 5. Enable database backups in Railway
