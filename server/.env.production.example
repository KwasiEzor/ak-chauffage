# Production Environment Variables
# ⚠️ CRITICAL: Update ALL values before deploying to production!

NODE_ENV=production
PORT=3000

# JWT Secret - Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ⚠️ MUST be changed! This is just an example.
JWT_SECRET=c34087dfd4c33f0141be1c44ffed61a3db5bee29b7dc8a6b694a7d7b5104ba10496966ed1bcee84ed23a68e54e4c275ab4ec84af6b5fe1aa9813ee4e930e89aa

# Admin Credentials
# ⚠️ MUST be changed! Default: admin/admin is insecure!
ADMIN_USERNAME=admin

# Generate password hash with: node -e "console.log(require('bcrypt').hashSync('YOUR_PASSWORD', 10))"
# Example password: AK_Chauffage_2026_Secure!
ADMIN_PASSWORD_HASH=$2b$10$MaXJGDvIjrQpOMLpelZyC.qVEBJYIpbE8IqdV4YTw9Smh4Bbt.UTi

# CORS - Your production domain(s)
# ⚠️ MUST be updated with your actual domain!
ALLOWED_ORIGINS=https://www.ak-chauffage.be,https://ak-chauffage.be

# Email Configuration (for contact form)
# Get SMTP credentials from your email provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=contact@ak-chauffage.be
SMTP_PASS=your-email-app-password-here
CONTACT_EMAIL=contact@ak-chauffage.be

# reCAPTCHA (optional - only if using Google reCAPTCHA)
# RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ============================================
# SECURITY CHECKLIST BEFORE DEPLOYMENT:
# ============================================
# [ ] Changed JWT_SECRET to new random value
# [ ] Changed ADMIN_PASSWORD_HASH to strong password
# [ ] Updated ALLOWED_ORIGINS with production domain
# [ ] Configured SMTP credentials for email
# [ ] Tested all environment variables
# [ ] Verified .env is in .gitignore
# [ ] Set up HTTPS/SSL certificate
# [ ] Configured firewall rules
# [ ] Set up automated backups
